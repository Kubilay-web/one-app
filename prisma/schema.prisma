// Invoice Model


model InvoiceModel {
  id          String   @id @default(cuid()) @map("_id")
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

