  // Tracking
  sentAt   DateTime? // When invoice was sent
  viewedAt DateTime? // When client viewed invoice
  paidAt   DateTime? // When invoice was paid

  // Relationships
  items InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoices")
}

// Invoice Item Model
